{
  "author": {
    "email": "gajus@gajus.com",
    "name": "Gajus Kuizinas",
    "url": "http://gajus.com"
  },
  "dependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "4.7.2",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@next/eslint-plugin-next": "^16.2.10",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "@typescript-eslint/parser": "^8.64.0",
    "@vitest/eslint-plugin": "^1.6.23",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-ava": "^17.0.1",
    "eslint-plugin-canonical": "^5.1.3",
    "eslint-plugin-fp": "^2.3.0",
    "eslint-plugin-functional": "^10.0.0",
    "eslint-plugin-import": "npm:eslint-plugin-import-x@^4.17.1",
    "eslint-plugin-jest": "^29.15.4",
    "eslint-plugin-jsdoc": "^63.2.0",
    "eslint-plugin-jsonc": "^3.3.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-lodash": "^8.0.0",
    "eslint-plugin-mocha": "^11.3.0",
    "eslint-plugin-modules-newline": "0.0.6",
    "eslint-plugin-n": "^18.2.2",
    "eslint-plugin-perfectionist": "^5.10.0",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-promise": "^7.3.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-unicorn": "^72.0.0",
    "eslint-plugin-yml": "^3.6.0",
    "eslint-plugin-zod": "^4.8.0",
    "globals": "^17.7.0",
    "graphql": "16.14.2"
  },
  "description": "Canonical ESLint Shareable Config",
  "devDependencies": {
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.9",
    "@semantic-release/npm": "^13.1.5",
    "eslint": "10.7.0",
    "husky": "^9.1.7",
    "semantic-release": "^25.0.8",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "exports": {
    ".": {
      "import": "./dist/configurations/index.js",
      "types": "./dist/configurations/index.d.ts"
    },
    "./*": {
      "import": "./dist/configurations/*.js",
      "types": "./dist/configurations/*.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "eslint",
    "config",
    "canonical"
  ],
  "license": "BSD-3-Clause",
  "main": "./eslintrc.js",
  "name": "eslint-config-canonical",
  "peerDependencies": {
    "eslint": "9 || ^10"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gajus/eslint-config-canonical"
  },
  "scripts": {
    "build": "tsc",
    "find-deprecated": "(cd scripts; node find-deprecated.js)",
    "generate-stats": "(cd scripts; node generate-stats.js)",
    "generate-typescript-compatibility-rules": "(cd scripts; node generate-typescript-compatibility-rules.js) && eslint configurations/typescript-compatibility.ts --fix",
    "lint": "eslint --report-unused-disable-directives .",
    "setup-dev": "(npm run build; npm link; cd scripts; npm ci; npm link eslint-config-canonical)"
  },
  "type": "module",
  "version": "1.0.0"
}
